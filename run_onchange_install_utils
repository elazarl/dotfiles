#!/bin/bash -xv

if [ ! -f ~/.cargo/env ]; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi
source ~/.cargo/env
if ! command -v cargo-binstall; then
  curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
fi
cargo binstall -y ripgrep skim starship zoxide atuin bat choose lsd eza \
  fd-find sheldon bob-nvim bottom procs \
  fselect sd jless qsv xcp xh tokei miniserve dysk bandwhich git-delta

# bob skips its "add to $PATH?" prompt when nvim-bin is already in PATH (dot_zshrc sets it for real shells)
PATH="$HOME/.local/share/bob/nvim-bin:$PATH" bob use stable

# macOS: fzf via brew (install brew first if missing)
if [ "$(uname -s)" = "Darwin" ]; then
  if ! command -v brew >/dev/null 2>&1; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
  brew install fzf
fi

if [ ! -d ~/.config/nvim ]; then
  rm -rf ~/.local/share/nvim ~/.local/state/nvim ~/.cache/nvim
  git clone --depth 1 https://github.com/AstroNvim/template ~/.config/nvim
  rm -rf ~/.config/nvim/.git
  ln -sf ~/.config/nvim-user/community.lua ~/.config/nvim/lua/community.lua
fi

